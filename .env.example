# Copy this file to .env and fill in your values
# NEVER commit .env to git

# SV cluster — internal model endpoint for DSPy optimization
# Confirm exact URL and port with your reviewer
OPENAI_API_BASE=http://SV_CLUSTER_IP:PORT/v1

# OpenAI API key — used for validation and demo only
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ENVIRONMENT=development
RECONCILER_MODE=demo
