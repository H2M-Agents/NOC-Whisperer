# Copy this file to .env and fill in your values
# NEVER commit .env to git

# SV cluster — internal model endpoint for DSPy optimization
# Use placeholders only in committed files
OPENAI_API_BASE=http://SV_CLUSTER_IP:PORT/v1
OPENAI_API_KEY=your-sv-cluster-api-key
DSPy_MODEL=openai/gpt-oss-20b
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ENVIRONMENT=development
RECONCILER_MODE=demo

# Demo mode — set true for live OTel data, false for synthetic
NOC_LIVE_MODE=false
